{
  "name": "@cdp/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-app Zod schemas, types, and constants.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ingest": {
      "types": "./dist/ingest.d.ts",
      "default": "./dist/ingest.js"
    },
    "./pagination": {
      "types": "./dist/pagination.d.ts",
      "default": "./dist/pagination.js"
    },
    "./tenant": {
      "types": "./dist/tenant.d.ts",
      "default": "./dist/tenant.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "echo 'lint via root config' && exit 0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
