{
  "name": "@datapp/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations, and client for the CDP.",
  "main": "./generated/client/index.js",
  "types": "./generated/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./generated/client/index.d.ts",
      "default": "./generated/client/index.js"
    }
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:deploy:ci": "prisma migrate deploy",
    "migrate:status": "dotenv -e ../../.env -- prisma migrate status",
    "migrate:reset": "dotenv -e ../../.env -- prisma migrate reset --skip-seed",
    "reset": "dotenv -e ../../.env -- prisma migrate reset",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "format": "prisma format",
    "validate": "dotenv -e ../../.env -- prisma validate",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
