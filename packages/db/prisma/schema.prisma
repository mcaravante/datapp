/// Daily blue-dollar quote captured from Bluelytics. Indexed lookups
/// by date back the USD toggle on `/insights` and `/reports`.
///
/// Tenants share the same rate (ARS is the same for everyone), so
/// there's no `tenant_id` here — keeps the row count tiny (one per day).
/// Bluelytics doesn't publish weekends/holidays; consumers should walk
/// back to the previous available date when the day is missing.
model CurrencyRate {
  /// UTC date of the quote. We use a real DATE column rather than a
  /// timestamp so equality lookups stay simple.
  date      DateTime @id @db.Date
  source    String   @default("bluelytics")
  blueBuy   Decimal  @map("blue_buy") @db.Decimal(14, 4)
  blueSell  Decimal  @map("blue_sell") @db.Decimal(14, 4)
  /// Average of buy/sell; precomputed so the conversion query stays
  /// on a single column.
  blueAvg   Decimal  @map("blue_avg") @db.Decimal(14, 4)
  fetchedAt DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  @@map("currency_rate")
}

/// Lifecycle state of an abandoned cart row.
///
/// Phase 3 (email marketing) consumes this to compute recovery KPIs
/// (recovered count, recovered revenue, time-to-recover) so the table
/// retains rows after their terminal state — they are never deleted by
/// the sweep.
enum AbandonedCartStatus {
  open      @map("open")
  recovered @map("recovered")
  expired   @map("expired")
  purged    @map("purged")

  @@map("abandoned_cart_status")
}

/// Historical record of carts that crossed the 24-hour idle threshold.
///
/// Populated every ~15 minutes by a BullMQ cron that pulls active Magento
/// carts whose `updated_at` is older than 24h. Rows are inserted as
/// `open` and then transition once on a terminal event:
///
/// - `recovered` when a subsequent Order arrives whose `magento_quote_id`
///   matches `magento_cart_id` (placed after `abandoned_at`).
/// - `expired` when the cart no longer comes back from Magento and
///   `abandoned_at` is older than the expiry window (default 30d).
/// - `purged` when the cart no longer comes back from Magento and is
///   younger than the expiry window (user emptied it manually).
model AbandonedCart {
  id                   String              @id @default(uuid(7)) @db.Uuid
  tenantId             String              @map("tenant_id") @db.Uuid
  magentoStoreId       String              @map("magento_store_id") @db.Uuid
  magentoCartId        Int                 @map("magento_cart_id")
  customerProfileId    String?             @map("customer_profile_id") @db.Uuid
  magentoCustomerId    String?             @map("magento_customer_id")
  customerEmail        String?             @map("customer_email")
  customerName         String?             @map("customer_name")
  isGuest              Boolean             @map("is_guest")
  itemsCount           Int                 @map("items_count")
  itemsQty             Int                 @map("items_qty")
  subtotal             Decimal             @db.Decimal(20, 4)
  grandTotal           Decimal             @map("grand_total") @db.Decimal(20, 4)
  currencyCode         String?             @map("currency_code") @db.Char(3)
  magentoCreatedAt     DateTime            @map("magento_created_at") @db.Timestamptz(6)
  magentoUpdatedAt     DateTime            @map("magento_updated_at") @db.Timestamptz(6)
  /// First time this cart crossed the 24h-idle threshold. Never updated.
  abandonedAt          DateTime            @map("abandoned_at") @db.Timestamptz(6)
  status               AbandonedCartStatus @default(open)
  recoveredAt          DateTime?           @map("recovered_at") @db.Timestamptz(6)
  recoveredByOrderId   String?             @map("recovered_by_order_id") @db.Uuid
  /// `Order.realRevenue` if available, otherwise `Order.grandTotal`.
  recoveredAmount      Decimal?            @map("recovered_amount") @db.Decimal(20, 4)
  expiredAt            DateTime?           @map("expired_at") @db.Timestamptz(6)
  syncedAt             DateTime            @default(now()) @map("synced_at") @db.Timestamptz(6)
  /// Magento native masked quote id (32-char alphanumeric, lives in
  /// `quote_id_mask`). Filled lazily the first time a recovery email is
  /// prepared for this cart, via the magento-client `getMaskedId` call.
  /// Used to build the `/pupe_abandoned/cart/restore?token=…` URL.
  magentoMaskedQuoteId String?             @map("magento_masked_quote_id") @db.VarChar(32)

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  magentoStore     MagentoStore     @relation(fields: [magentoStoreId], references: [id], onDelete: Cascade)
  customer         CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  recoveredByOrder Order?           @relation("AbandonedCartRecovery", fields: [recoveredByOrderId], references: [id], onDelete: SetNull)
  emailSends       EmailSend[]

  @@unique([tenantId, magentoStoreId, magentoCartId])
  @@index([tenantId, status, abandonedAt(sort: Desc)])
  @@index([tenantId, status, recoveredAt(sort: Desc)])
  @@index([tenantId, customerProfileId])
  @@index([tenantId, magentoMaskedQuoteId])
  @@map("abandoned_cart")
}

