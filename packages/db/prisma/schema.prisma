// =====================================================================
//  Phase 3 — Email engine (abandoned-cart recovery vertical)
//  See docs/adr/0007-phase3-abandoned-cart-recovery-vertical.md.
//
//  EmailTemplate / EmailCampaign / EmailCampaignStage / EmailSend /
//  EmailEvent / EmailSuppression are intentionally generic so future
//  Phase 3 surfaces (broadcast, segments) reuse them; only the
//  EmailCampaignTrigger enum is restricted to `abandoned_cart_stage`
//  for now.
// =====================================================================

enum EmailTemplateChannel {
  abandoned_cart
  /// Reserved for future Phase 3 use cases (password reset, receipts).
  transactional
  /// Reserved for future broadcast campaigns. Not implemented in this iteration.
  marketing

  @@map("email_template_channel")
}

enum EmailCampaignStatus {
  draft
  active
  paused
  archived

  @@map("email_campaign_status")
}

enum EmailCampaignTrigger {
  /// Single trigger value in this iteration. New values gated by ADR.
  abandoned_cart_stage

  @@map("email_campaign_trigger")
}

enum CouponMode {
  none
  /// Operator pre-creates the rule + code in Magento; CDP only injects the
  /// literal `couponStaticCode` into the recovery URL and the template.
  static_code @map("static")
  /// CDP creates a Magento sales-rule per stage on first use, then calls
  /// `/V1/coupons/generate` for one new code per send.
  unique_code @map("unique")

  @@map("coupon_mode")
}

enum EmailSendStatus {
  pending
  queued
  delivered
  bounced
  complained
  failed
  suppressed
  cancelled

  @@map("email_send_status")
}

enum EmailEventType {
  delivered
  delivery_delayed
  bounced
  complained
  opened
  clicked
  failed
  unsubscribed

  @@map("email_event_type")
}

enum SuppressionReason {
  manual
  hard_bounce
  spam_complaint
  unsubscribed
  invalid_address
  /// Outbound blocked because EMAIL_DRY_RUN was on and the recipient was
  /// not in EMAIL_TEST_RECIPIENT_ALLOWLIST. Logged for forensics.
  test_allowlist

  @@map("suppression_reason")
}

/// Operator-authored email template. Multiple campaigns can reference the
/// same template; each version is identified by `updatedAt` for cache
/// invalidation in the renderer.
model EmailTemplate {
  id        String               @id @default(uuid(7)) @db.Uuid
  tenantId  String               @map("tenant_id") @db.Uuid
  channel   EmailTemplateChannel
  /// URL-friendly slug, unique per tenant.
  slug      String
  name      String
  /// Handlebars template; renders to plain text (no HTML).
  subject   String
  /// MJML or raw HTML — see `format`. Handlebars variables wrapped in
  /// `{{name}}` (escaped). Triple-stash forbidden for user-derived data
  /// per the renderer policy.
  bodyHtml  String               @map("body_html")
  bodyText  String?              @map("body_text")
  /// JSON-Schema describing the expected variables. Used by the renderer
  /// to fail-fast on missing data instead of producing a broken email.
  variables Json                 @default("{}")
  /// `mjml` (default — runs through MJML compile then Handlebars) or
  /// `html` (Handlebars only, raw HTML).
  format    String               @default("mjml")
  isActive  Boolean              @default(true) @map("is_active")
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages EmailCampaignStage[]

  @@unique([tenantId, slug])
  @@index([tenantId, channel, isActive])
  @@map("email_template")
}

/// Logical campaign — a sequence of stages bound to a trigger. Phase 3
/// vertical: only `abandoned_cart_stage` campaigns are supported.
model EmailCampaign {
  id           String               @id @default(uuid(7)) @db.Uuid
  tenantId     String               @map("tenant_id") @db.Uuid
  slug         String
  name         String
  trigger      EmailCampaignTrigger @default(abandoned_cart_stage)
  status       EmailCampaignStatus  @default(draft)
  /// Override `RESEND_FROM_EMAIL`. Null = inherit env default.
  fromEmail    String?              @map("from_email")
  replyToEmail String?              @map("reply_to_email")
  /// Audit metadata (createdBy id, archivedBy id, free-form notes).
  metadata     Json                 @default("{}")
  archivedAt   DateTime?            @map("archived_at") @db.Timestamptz(6)
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages EmailCampaignStage[]
  sends  EmailSend[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("email_campaign")
}

/// One stage of a campaign — a delay (offset from `AbandonedCart.abandonedAt`),
/// a template, and a coupon configuration.
model EmailCampaignStage {
  id                 String     @id @default(uuid(7)) @db.Uuid
  tenantId           String     @map("tenant_id") @db.Uuid
  campaignId         String     @map("campaign_id") @db.Uuid
  templateId         String     @map("template_id") @db.Uuid
  /// 1-based ordering inside the campaign.
  position           Int
  /// Hours since `AbandonedCart.abandonedAt` before this stage fires.
  delayHours         Int        @map("delay_hours")
  couponMode         CouponMode @default(none) @map("coupon_mode")
  /// For `static_code` mode: the literal Magento coupon to inject.
  /// For `unique_code` mode: leave null; codes are generated per send.
  couponStaticCode   String?    @map("coupon_static_code")
  /// For `unique_code` mode: the Magento sales-rule id created lazily on
  /// first use. Reused across sends; cleaned up on campaign archive.
  magentoSalesRuleId Int?       @map("magento_sales_rule_id")
  /// Display-only — Magento is the source of truth for the rule.
  couponDiscount     Decimal?   @map("coupon_discount") @db.Decimal(20, 4)
  /// `percent` or `fixed`.
  couponDiscountType String?    @map("coupon_discount_type")
  /// Hours after issue before the unique coupon expires; null = no expiry.
  couponTtlHours     Int?       @map("coupon_ttl_hours")
  isActive           Boolean    @default(true) @map("is_active")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  sends    EmailSend[]

  @@unique([campaignId, position])
  @@index([tenantId, isActive, delayHours])
  @@map("email_campaign_stage")
}

/// One concrete delivery attempt. Created in `pending` state, transitioned
/// through `queued`/`delivered`/`bounced`/etc. by the dispatcher and the
/// Resend webhook. Unique `(tenantId, idempotencyKey)` is the hard guard
/// against double-sending.
model EmailSend {
  id                 String          @id @default(uuid(7)) @db.Uuid
  tenantId           String          @map("tenant_id") @db.Uuid
  campaignId         String          @map("campaign_id") @db.Uuid
  stageId            String          @map("stage_id") @db.Uuid
  /// Source cart. `SetNull` so the audit row survives a cart deletion.
  abandonedCartId    String?         @map("abandoned_cart_id") @db.Uuid
  customerProfileId  String?         @map("customer_profile_id") @db.Uuid
  /// Lower-cased recipient email. `toEmailHash` is the log-safe lookup key.
  toEmail            String          @map("to_email")
  toEmailHash        String          @map("to_email_hash") @db.Char(64)
  fromEmail          String          @map("from_email")
  subject            String
  /// `send:{tenantId}:{cartId}:{stageId}`. Also doubles as BullMQ jobId.
  idempotencyKey     String          @map("idempotency_key")
  /// Resend API id (after ack). Opaque string, not a uuid.
  resendMessageId    String?         @map("resend_message_id")
  status             EmailSendStatus @default(pending)
  lastEventType      EmailEventType? @map("last_event_type")
  lastEventAt        DateTime?       @map("last_event_at") @db.Timestamptz(6)
  /// Coupon emitted with this send (if any).
  couponCode         String?         @map("coupon_code")
  couponSource       CouponMode?     @map("coupon_source")
  /// For `unique_code` mode — links the code back to its sales rule for cleanup.
  magentoSalesRuleId Int?            @map("magento_sales_rule_id")
  recoveryUrl        String          @map("recovery_url")
  /// Render-time variable snapshot, for replay/debug. PII included; access controlled.
  renderContext      Json            @default("{}") @map("render_context")
  /// Filled when status is `failed` or `suppressed`.
  errorMessage       String?         @map("error_message")
  scheduledFor       DateTime        @map("scheduled_for") @db.Timestamptz(6)
  sentAt             DateTime?       @map("sent_at") @db.Timestamptz(6)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign EmailCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stage    EmailCampaignStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  cart     AbandonedCart?     @relation(fields: [abandonedCartId], references: [id], onDelete: SetNull)
  customer CustomerProfile?   @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  events   EmailEvent[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, abandonedCartId, stageId])
  @@index([tenantId, toEmailHash, createdAt(sort: Desc)])
  @@index([tenantId, resendMessageId])
  @@map("email_send")
}

/// Webhook event from Resend. `(tenantId, providerEventId)` is unique to
/// reject replays.
model EmailEvent {
  id              String         @id @default(uuid(7)) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  emailSendId     String         @map("email_send_id") @db.Uuid
  /// `resend.com` event id from webhook payload — natural idempotency key.
  providerEventId String         @map("provider_event_id")
  eventType       EmailEventType @map("event_type")
  occurredAt      DateTime       @map("occurred_at") @db.Timestamptz(6)
  payload         Json           @default("{}")
  receivedAt      DateTime       @default(now()) @map("received_at") @db.Timestamptz(6)

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  send   EmailSend @relation(fields: [emailSendId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerEventId])
  @@index([tenantId, eventType, occurredAt(sort: Desc)])
  @@index([emailSendId, occurredAt])
  @@map("email_event")
}

/// Per-tenant suppression list. Bounces and complaints auto-populate via
/// the Resend webhook. Operators can add manual entries (e.g. customer
/// asks via support).
model EmailSuppression {
  id        String            @id @default(uuid(7)) @db.Uuid
  tenantId  String            @map("tenant_id") @db.Uuid
  emailHash String            @map("email_hash") @db.Char(64)
  /// Lower-cased plain text. Kept for admin display only — never logged.
  email     String
  reason    SuppressionReason
  /// Free-text origin (`resend.bounced`, `admin.ui`, `self.unsubscribe`, …).
  source    String?
  notes     String?
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, emailHash])
  @@index([tenantId, reason])
  @@map("email_suppression")
}

/// Operator-uploaded image assets (logos, hero images, product photos)
/// referenced by email templates. The bytes live in the row itself —
/// fine for the email-recovery use case where assets are small (≤ a few
/// MB each) and we want zero new infra. A future iteration may move
/// large/many assets to S3-compatible storage; the current shape is
/// designed to be replaceable via a `storageKey` field if so.
///
/// Served publicly at `/media/:id/:filename` (no auth — the uuid v7 id
/// is the security boundary, like S3 pre-signed URLs). The `:filename`
/// path segment is informational, kept so email clients show a sane
/// download name and so referrers / logs are debuggable.
model MediaAsset {
  id           String   @id @default(uuid(7)) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  /// Original filename at upload time, sanitized to a safe charset.
  filename     String
  /// IANA mime, e.g. `image/png`, `image/jpeg`, `image/webp`, `image/gif`.
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  bytes        Bytes
  uploadedById String?  @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy     User?                 @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  brandingLogos  TenantEmailBranding[] @relation("BrandingLogo")

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("media_asset")
}

/// Tenant-level email branding shell that wraps every send: header
/// (logo image), footer (operator-authored HTML), sender info shown in
/// the footer for CAN-SPAM-style transparency. 1:1 with `Tenant`.
///
/// Each field is independently optional. When a tenant has no branding
/// row, sends still go out, just without the wrapper — only the
/// unsubscribe link is appended (mandatory).
model TenantEmailBranding {
  tenantId         String  @id @map("tenant_id") @db.Uuid
  /// Logo shown at the top of every email. FK to a MediaAsset uploaded
  /// via the existing /v1/admin/media surface.
  logoMediaAssetId String? @map("logo_media_asset_id") @db.Uuid
  /// Max display width of the logo in pixels. Default 180 fits common
  /// email column widths (Gmail / Outlook ~580 px usable).
  logoMaxWidthPx   Int     @default(180) @map("logo_max_width_px")
  /// Hex string e.g. `#111111`. Used for the wrapper background and
  /// (eventually) accent buttons in default templates.
  primaryColor     String? @map("primary_color")
  /// Free HTML rendered inside the email footer (under the body).
  /// Sanitized at render time — only safe inline tags allowed.
  footerHtml       String? @map("footer_html")
  /// Sender display name shown in the footer + used as the friendly
  /// part of the From header when set.
  senderName       String? @map("sender_name")
  /// Physical address (street, city, country). Mostly relevant for
  /// CAN-SPAM (US); kept here so jurisdictions that require it can
  /// surface it consistently.
  senderAddress    String? @map("sender_address")
  /// Override of the default unsubscribe phrase. The token-bearing
  /// link is appended automatically.
  unsubscribeText  String  @default("Si no querés recibir más estos emails, podés desuscribirte acá.") @map("unsubscribe_text")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoAsset  MediaAsset? @relation("BrandingLogo", fields: [logoMediaAssetId], references: [id], onDelete: SetNull)

  @@map("tenant_email_branding")
}
