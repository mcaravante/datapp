# =====================================================================
# CDP — Environment variables
# =====================================================================
# Copy to `.env` and fill in. Validated at startup by Zod schemas.
# DO NOT commit `.env` files. `.env.example` is the only env file in VCS.
# =====================================================================

# ---- Runtime ---------------------------------------------------------
# NODE_ENV is set by the runtime (Next.js / Nest CLI / Docker entry) — DO NOT
# set it here. Putting it in `.env` clobbers Next's automatic value during
# `next build` and breaks the production prerender.
LOG_LEVEL=debug

# ---- PostgreSQL 16 ---------------------------------------------------
# DATABASE_URL is used by the application (with connection pooling).
# DIRECT_URL is used by Prisma migrations (direct, unpooled connection).
# Host port 5433 (not 5432) so the dev compose can coexist with other
# local Postgres instances.
DATABASE_URL="postgresql://cdp:cdp@localhost:5433/cdp?schema=public"
DIRECT_URL="postgresql://cdp:cdp@localhost:5433/cdp?schema=public"

# ---- Redis 7 (BullMQ + cache) ---------------------------------------
# Host port 6380 (not 6379) for the same reason.
REDIS_URL="redis://localhost:6380/0"

# ---- JWT (RS256, PEM) ------------------------------------------------
# Generate with:
#   openssl genpkey -algorithm RSA -out priv.pem -pkeyopt rsa_keygen_bits:4096
#   openssl rsa -in priv.pem -pubout -out pub.pem
# Paste the full PEM (including BEGIN/END lines) inside double quotes,
# escaping newlines as \n.
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# ---- Auth.js (NextAuth) ---------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3001"

# ---- Envelope encryption master key ---------------------------------
# 32-byte key, hex-encoded. Generate with: openssl rand -hex 32
# Used to encrypt sensitive columns (Magento tokens, TOTP secrets).
ENCRYPTION_MASTER_KEY=""

# ---- Public URLs ----------------------------------------------------
# Host port 3010 (not 3000) so the dev API doesn't clash with other
# Node services / Docker port forwards on the same host.
PORT=3010
APP_URL_API="http://localhost:3010"
APP_URL_ADMIN="http://localhost:3001"

# ---- CORS allowlist (comma-separated) -------------------------------
CORS_ALLOWED_ORIGINS="http://localhost:3001"

# ---- Magento integration --------------------------------------------
# Per-tenant secrets live in the `magento_store` table; these are dev
# defaults used by the CLI / single-tenant deployments.
MAGENTO_BASE_URL="https://your-magento-store.example.com"
MAGENTO_ADMIN_TOKEN=""
MAGENTO_HMAC_SECRET=""
MAGENTO_RATE_LIMIT_RPS=4

# ---- Sentry ---------------------------------------------------------
SENTRY_DSN_API=""
SENTRY_DSN_ADMIN=""
# Make the admin DSN public so the browser bundle can load it. Same
# value as SENTRY_DSN_ADMIN — Next.js requires the NEXT_PUBLIC_ prefix
# to inline at build time.
NEXT_PUBLIC_SENTRY_DSN_ADMIN=""
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ---- SMTP (password reset emails) -----------------------------------
# Required to actually send the password-reset link. Leave SMTP_HOST
# empty in dev to log the link to stdout instead of sending. Works with
# Resend, Mailgun, SES, Gmail, or any standard SMTP relay.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE=false
SMTP_FROM="CDP <no-reply@example.com>"

# ---- Backups (Cloudflare R2 + age encryption) -----------------------
BACKUP_S3_ENDPOINT=""
BACKUP_S3_BUCKET=""
BACKUP_S3_ACCESS_KEY_ID=""
BACKUP_S3_SECRET_ACCESS_KEY=""
BACKUP_S3_REGION=auto
BACKUP_AGE_RECIPIENT=""

# ---- Time zone (presentation only — storage is UTC) -----------------
DEFAULT_TIMEZONE="America/Argentina/Buenos_Aires"

# ---- Tenancy --------------------------------------------------------
# Default tenant slug used by single-tenant CLI commands and seed data.
DEFAULT_TENANT_SLUG=acme

# ---- Feature flags --------------------------------------------------
FEATURE_2FA_ENFORCED=false

# ---- Google sign-in -------------------------------------------------
# OAuth client ID + secret from Google Cloud Console (the same Client ID
# is used by both the API for id_token verification and the admin for
# the OAuth flow). Leave empty to disable the "Continue with Google"
# button.
GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Bootstrap email — the first Google sign-in matching this address gets
# auto-promoted to super_admin. Leave empty after the owner is created
# (or right from the start if you prefer to seed manually).
OWNER_EMAIL=""
