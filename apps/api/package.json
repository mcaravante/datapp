    "@datapp/shared": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.7",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@sentry/node": "^8.40.0",
    "@types/qrcode": "^1.5.6",
    "argon2": "^0.41.1",
    "bullmq": "^5.28.0",
    "google-auth-library": "^9.15.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "mjml": "^5.1.0",
    "nestjs-pino": "^4.1.0",
    "nestjs-zod": "^3.0.0",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "p-retry": "4.6.2",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.2",
