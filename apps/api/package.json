{
  "name": "@datapp/api",
  "version": "0.0.0",
  "private": true,
  "description": "CDP API + BullMQ workers (NestJS).",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "cli": "node dist/cli.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
